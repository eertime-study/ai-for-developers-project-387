{
  "name": "call-calendar-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Call Calendar backend — Fastify API implemented from the OpenAPI contract, in-memory storage.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "gen:api": "openapi-typescript ../spec/tsp-output/@typespec/openapi3/openapi.yaml -o src/api/schema.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.3.0",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.8.5",
    "fastify-openapi-glue": "^4.11.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
